{
  "title": "Registratieformulier Muziek & Emotieregulatie Studie",
  "description": "Dit formulier verzamelt basisgegevens van deelnemers voor een onderzoek naar de invloed van muziek op emotieregulatie. Deelnemers vullen hun gegevens in en kiezen beschikbare tijdslots.",
  "sections": [
    {
      "id": "personal_info",
      "title": "Persoonlijke gegevens",
      "fields": [
        {
          "id": "full_name",
          "label": "Volledige naam",
          "type": "text",
          "required": true
        },
        {
          "id": "email",
          "label": "E-mailadres",
          "type": "email",
          "required": true,
          "validation": {
            "regex": ".+@.+\\..+",
            "error_message": "Gelieve een geldig e-mailadres in te vullen."
          }
        },
        {
          "id": "age",
          "label": "Leeftijd",
          "type": "number",
          "required": true,
          "min": 18,
          "max": 70
        }
      ]
    },
    {
      "id": "availability",
      "title": "Beschikbaarheid",
      "fields": [
        {
          "id": "preferred_timeslot",
          "label": "Kies je beschikbare tijdslot(s)",
          "type": "checkbox",
          "required": true,
          "options": [
            "Voormiddag (09:00–12:00)",
            "Namiddag (13:00–17:00)",
            "Avond (18:00–21:00)"
          ]
        }
      ]
    },
    {
      "id": "study_info",
      "title": "Informatie over deelname",
      "fields": [
        {
          "id": "music_experience",
          "label": "Heb je ervaring met muziekinterventies?",
          "type": "multiple_choice",
          "required": false,
          "options": [
            "Ja, regelmatig",
            "Af en toe",
            "Nee, nooit"
          ]
        },
        {
          "id": "consent",
          "label": "Ik ga akkoord met deelname aan dit onderzoek en de verwerking van mijn gegevens volgens de richtlijnen.",
          "type": "checkbox",
          "required": true
        }
      ]
    }
  ],
  "metadata": {
    "version": "1.0",
    "created_by": "Astrid Verschraege en Timothy D'Hoe",
    "study_phase": "registratie"
  }
}



const FRUIT_LIST = [
  "🍇 Druiven", "🍉 Watermeloen", "🍊 Mandarijn",
  "🍋 Citroen", "🍋‍🟩 Limoen", "🍌 Banaan", "🍍 Ananas",
  "🥭 Mango", "🍏 Appel", "🍐 Peer",
  "🍑 Perzik", "🍒 Kersen", "🍓 Aardbei", "🫐 Blauwe bessen",
  "🥝 Kiwi", "🥥 Kokosnoot"
];

function formOnSubmit(e) {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName("Form Responses 1");
  const row = e.range.getRow();

  const existing = sheet.getRange(2, 11, sheet.getLastRow() - 1, 1)
    .getValues()
    .flat()
    .filter(x => x);

  const available = FRUIT_LIST.filter(f => !existing.includes(f));

  if (available.length === 0) {
    sheet.getRange(row, 11).setValue("⚠️ Geen fruit beschikbaar");
    return;
  }

  const fruit = available[Math.floor(Math.random() * available.length)];

  sheet.getRange(row, 11).setValue(fruit);

  // 👉 NIEUW: stuur automatisch de mail
  sendParticipationEmail(row);
}


function sendParticipationEmail(row) {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName("Formulierreacties 1");

  // Kolommen:
  // D = e-mailadres (kolom 4)
  // L = participatiecode (kolom 11)

  const email = sheet.getRange(row, 4).getValue();
  const code = sheet.getRange(row, 11).getValue();

  if (!email || !code) {
    return; // veiligheid: geen mail versturen zonder info
  }

  const subject = "Uw participatiecode voor het onderzoek";
  const body =
    "Beste deelnemer,\n\n" +
    "Bedankt voor uw deelname aan de <i>Regulation of Emotions through Music</i> studie.\n\n" +
    "Uw persoonlijke participatiecode is:\n\n" +
    code + "\n\n" +
    "Bewaar deze code goed. U heeft ze nodig voor verdere communicatie en check-in formulieren binnen het onderzoek.\n" +
    "Alvast bedankt voor uw participatie\n\n" +
    "Met vriendelijke groeten,\n" +

    "Het REM-onderzoeksteam";

  MailApp.sendEmail(email, subject, body);
}